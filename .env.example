# ---- AWS ----
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key

# ---- S3 (document storage) ----
S3_BUCKET=mediassist-documents
S3_PREFIX=docs/

# ---- Bedrock (LLM) ----
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20240620-v1:0

# ---- Cognito ----
COGNITO_USER_POOL_ID=ap-south-1_xxxxxxxx
COGNITO_APP_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
COGNITO_REGION=ap-south-1

# ---- Qdrant Cloud ----
QDRANT_URL=https://xxxx-xxxx.cloud.qdrant.io:6333
QDRANT_API_KEY=your-qdrant-api-key
QDRANT_COLLECTION=mediassist_docs

# ---- Local data (used by ingestion if S3 not configured / for dev) ----
DATA_DIR=../data
SQLITE_DB_PATH=../data/mediassist.db

# ---- CORS (comma-separated; add your Amplify URL after deploy) ----
FRONTEND_ORIGINS=http://localhost:3000,https://main.dxxxxxxxxx.amplifyapp.com
